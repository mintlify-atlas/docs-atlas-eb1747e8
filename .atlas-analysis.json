  "keyFeatures": [
    "16-role RBAC system with fine-grained action-level permissions",
    "Multi-tenant scoping (global → country → city → business → branch)",
    "13-state order state machine with exception handling",
    "Business portal with catalog, orders, branches, and settlements",
    "Operative portals for kitchen, cashier, and waiter roles",
    "Customer marketplace with guest and registered checkout",
    "WhatsApp bot integration for customer ordering",
    "Wompi payment gateway integration with webhook verification",
    "Celery background jobs with Redis broker",
    "Comprehensive audit trail and structured logging"
  ],
